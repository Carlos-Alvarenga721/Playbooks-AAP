{# Template Jinja2 para el reporte CIS #}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Reporte CIS Compliance - {{ inventory_hostname }}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    h1 { color: #cc0000; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
    th { background-color: #cc0000; color: white; }
    .pass { color: green; font-weight: bold; }
    .fail { color: red; font-weight: bold; }
  </style>
</head>
<body>
  <h1>Reporte CIS Compliance</h1>
  <p><strong>Host:</strong> {{ inventory_hostname }}</p>
  <p><strong>Fecha:</strong> {{ ansible_date_time.date }}</p>
  <p><strong>Nivel CIS:</strong> {{ cis_audit_level }}</p>

  <h2>Resultados</h2>
  <table>
    <tr>
      <th>Control CIS</th>
      <th>Descripcion</th>
      <th>Estado</th>
    </tr>
    {% for result in cis_audit_results | default([]) %}
    <tr>
      <td>{{ result.control }}</td>
      <td>{{ result.description }}</td>
      <td class="{{ 'pass' if result.status == 'PASS' else 'fail' }}">{{ result.status }}</td>
    </tr>
    {% else %}
    <tr>
      <td colspan="3">Sin resultados disponibles</td>
    </tr>
    {% endfor %}
  </table>
</body>
</html>
